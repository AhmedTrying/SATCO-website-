# SATCO admin dashboard — environment template. Copy to .env.local and fill in.
# .env.local is gitignored; never commit real credentials.

# Adapter backend: "local" (JSON files under data/, offline) or "neon" (Postgres).
DATA_BACKEND=neon

# Neon Postgres connection string — from the Neon console (or the Vercel ↔ Neon
# integration, which also injects it into the Vercel project's env). Use the POOLED
# endpoint (host contains "-pooler"). Required when DATA_BACKEND=neon.
DATABASE_URL=postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DB?sslmode=require

# Optional: direct (non-pooled) endpoint for single-session tools.
DATABASE_URL_UNPOOLED=postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/DB?sslmode=require

# Optional: Vercel deploy hook for the site project. On Publish the dashboard pings
# this to rebuild the live site (which pulls published content from Neon at build).
# Vercel → <site project> → Settings → Git → Deploy Hooks. Leave empty to disable.
VERCEL_DEPLOY_HOOK_URL=
